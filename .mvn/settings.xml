<settings>
    <mirrors>
        <mirror>
            <id>marc-te-mirror</id>
            <mirrorOf>marc-te,marc-te-main</mirrorOf>
            <url>https://repo.maven.apache.org/maven2</url>
        </mirror>
        <mirror>
            <id>santesuite-mirror</id>
            <mirrorOf>santesute-main,santesuite-main</mirrorOf>
            <url>https://repo.maven.apache.org/maven2</url>
        </mirror>
    </mirrors>

    <profiles>
        <profile>
            <id>openmrs-repos</id>
            <pluginRepositories>
                <pluginRepository>
                    <id>openmrs-repo</id>
                    <name>OpenMRS Public Repository</name>
                    <url>https://mavenrepo.openmrs.org/public</url>
                </pluginRepository>
            </pluginRepositories>
            <repositories>
                <repository>
                    <id>openmrs-repo</id>
                    <name>OpenMRS Public Repository</name>
                    <url>https://mavenrepo.openmrs.org/public</url>
                </repository>
            </repositories>
        </profile>
    </profiles>
    <activeProfiles>
        <activeProfile>openmrs-repos</activeProfile>
    </activeProfiles>
</settings>
